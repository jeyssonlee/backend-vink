# --- CONFIGURACIÓN DEL SERVIDOR ---
PORT=3000
NODE_ENV=development
# URL de tu frontend para que el CORS que configuró Jules funcione
FRONTEND_URL=http://localhost:3001 

# --- BASE DE DATOS (POSTGRESQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=soporte
DB_PASSWORD=soporte
DB_NAME=erp_hub

# --- MENSAJERÍA (RABBITMQ) ---
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_QUEUE=vink_orders_queue

# --- SEGURIDAD ---
# Usa una cadena larga y compleja para tus JWT o sesiones
JWT_SECRET=una_clave_super_secreta_y_larga_123!